{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": [
    "src/trs/pages/admin",
    "src/trs/pages/approver",
    "src/trs/pages/lead",
    "src/trs/pages/RecipientFlow.tsx",
    "src/trs/pages/DocumentsValidationPages.tsx",
    "src/trs/pages/FieldSchemaPage.tsx",
    "src/trs/layout/TrsModuleLayout.tsx",
    "src/trs/components",
    "src/trs/barcode.ts",
    "src/pages"
  ]
}
